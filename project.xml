<?xml version="1.0" encoding="utf-8"?>
<project
    xmlns="http://lime.openfl.org/project/1.0.4"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://lime.openfl.org/project/1.0.4 http://lime.openfl.org/xsd/project-1.0.4.xsd">

    <meta version="0.0.1"
        title="CS2 Workshop Tools plugin installer"
        description="The CS2 Workshop Tools plugin enhances 
        your workflow of creating custom CS2 weapon finishes 
        by integrating some useful features and tools to 
        the Adobe Substance Painter." />

    <app main="Main"
        file="CS2-WT plugin installer"
        path="build" />

    <window width="575" 
        height="350" 
        fps="144"
        background="#000000"
        borderless="false"
        resizable="true"
        if="desktop"/>

    <window width="0" 
        height="0" 
        if="html"/>

    <!-- classpath, haxe libs -->
    <source path="src" />

    <assets path="assets" include="*" />

    <haxelib name="openfl" />
    <haxelib name="actuate" />

    <haxelib name="haxeui-core" />
    <haxelib name="haxeui-openfl" />
</project>
