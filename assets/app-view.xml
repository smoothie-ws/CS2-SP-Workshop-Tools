<?xml version="1.0" encoding="utf-8" ?>
<vbox id="root">
    <style source="style.css" />

    <hbox id="menuBar">
        <label text="Lorem Ipsum" />
        <spacer width="100%" />
        <button id="minimizeButton" icon="assets/icons/icon_min.png" tooltip="minimize"/>
        <button id="exitButton" icon="assets/icons/icon_close.png" tooltip="close"/>
    </hbox>
    
    <vbox id="mainContent">
        <vbox id="optionsBox">
            <hbox>
                <label text="CS2 path:" verticalAlign="center" />
                <textfield placeholder="Enter some text" verticalAlign="center" />
            </hbox>

            <hbox>
                <label text="Password field:" verticalAlign="center" />
                <textfield placeholder="Enter password" verticalAlign="center" />
            </hbox>
        </vbox>

        <hbox id="confirmationBox">
            <spacer width="100%"/>
            <button id="installButton" text="Install" />
            <button id="deleteButton" text="Delete" />
            <spacer width="100%"/>
        </hbox>
    </vbox>
</vbox>